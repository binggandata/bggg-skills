.DS_Store
__pycache__/
*.py[cod]

# Skill runtime outputs should stay local.
**/projects/*
!**/projects/.gitkeep
**/outputs/*
!**/outputs/.gitkeep
**/downloads/*
!**/downloads/.gitkeep

# Large generated design artifacts.
*.psd
*.preview.png
*.zip

# Media and research sidecars generated by TikTok workflows.
*.mp4
*.mov
*.webm
*.mkv
*.m4v
*.mp3
*.wav
*.srt
*.ass
*.info.json
download_manifest.json
.bggg-tiktok-download-archive.txt
